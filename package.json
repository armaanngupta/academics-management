{
  "name": "marksheet-management-system",
  "version": "1.0.0",
  "description": "A complete MERN stack application for managing student marksheets at institutional level",
  "main": "index.js",
  "scripts": {
    "dev": "node scripts/run-services.js dev",
    "start": "node scripts/run-services.js start",
    "backend": "npm --prefix backend start",
    "backend:dev": "npm --prefix backend run dev",
    "frontend": "npm --prefix frontend start",
    "frontend:build": "npm --prefix frontend run build",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "marksheet",
    "management",
    "system",
    "education",
    "institution",
    "mern",
    "react",
    "node",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/marksheet-management"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "directories": {
    "backend": "backend/",
    "frontend": "frontend/"
  },
  "documentation": {
    "quickStart": "QUICKSTART.md",
    "fullGuide": "README.md",
    "api": "API_DOCUMENTATION.md",
    "database": "MONGODB_SETUP.md",
    "deployment": "DEPLOYMENT.md",
    "testing": "TESTING_GUIDE.md",
    "troubleshooting": "TROUBLESHOOTING.md",
    "index": "INDEX.md"
  }
}
