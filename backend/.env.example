# MongoDB Connection URI
# For Local: mongodb://localhost:27017/marksheet_management
# For Atlas: mongodb+srv://username:password@cluster.mongodb.net/marksheet_management?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/marksheet_management

# Server Port
PORT=5000

# JWT Secret Key (Change this in production to a long, random string)
JWT_SECRET=your_jwt_secret_key_change_in_production

# Environment (development or production)
NODE_ENV=development
